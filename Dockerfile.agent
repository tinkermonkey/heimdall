# ============================================================================
# Heimdall Design System — Agent Environment
# ============================================================================
FROM switchyard-orchestrator:latest

USER root

# ============================================================================
# Playwright/Chromium system dependencies + font rendering consistency
# ============================================================================
RUN apt-get update -qq && \
    apt-get install -y --no-install-recommends \
        libxcomposite1 \
        libxdamage1 \
        libxfixes3 \
        libxrandr2 \
        libxcursor1 \
        libxrender1 \
        libxcb-shm0 \
        libpango-1.0-0 \
        libpangocairo-1.0-0 \
        libcairo2 \
        libcairo-gobject2 \
        libgdk-pixbuf-2.0-0 \
        libgtk-3-0t64 \
        libharfbuzz0b \
        libfontconfig1 \
        libfreetype6 \
        libdbus-glib-1-2 \
        xvfb \
        fonts-liberation \
        fonts-noto-color-emoji \
        libnss3 \
        libnspr4 \
        libatk1.0-0 \
        libatk-bridge2.0-0 \
        libcups2 \
        libdrm2 \
        libgbm1 \
        libxkbcommon0 \
        libasound2t64 \
        libatspi2.0-0 \
        fontconfig \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# ============================================================================
# Fontconfig: deterministic rendering (no hinting, grayscale AA)
# Prevents pixel diffs from font rendering variations across environments
# ============================================================================
RUN mkdir -p /etc/fonts && \
    cat > /etc/fonts/local.conf << 'EOF'
<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "fonts.dtd">
<fontconfig>
  <match target="font">
    <edit name="hinting" mode="assign"><bool>false</bool></edit>
    <edit name="autohint" mode="assign"><bool>false</bool></edit>
    <edit name="hintstyle" mode="assign"><const>hintnone</const></edit>
    <edit name="antialias" mode="assign"><bool>true</bool></edit>
    <edit name="rgba" mode="assign"><const>none</const></edit>
    <edit name="lcdfilter" mode="assign"><const>lcdnone</const></edit>
  </match>
</fontconfig>
EOF

# ============================================================================
# Install project fonts system-wide for consistent file:// rendering
# ============================================================================
COPY public/fonts /usr/share/fonts/heimdall
RUN fc-cache -f

# ============================================================================
# Pre-install project dependencies
# ============================================================================
WORKDIR /workspace/heimdall

COPY package.json package-lock.json ./

RUN --mount=type=cache,target=/root/.npm \
    npm ci --ignore-scripts

# ============================================================================
# Install Playwright Chromium browser
# ============================================================================
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers
RUN npx playwright install chromium

# ============================================================================
# Fix ownership of pre-installed node_modules and browser cache
# ============================================================================
RUN chown -R orchestrator:orchestrator /workspace/heimdall/node_modules && \
    chmod -R a+r /opt/playwright-browsers

# ============================================================================
# Runtime environment
# ============================================================================
ENV CI=true

# ============================================================================
# Switch to runtime user
# ============================================================================
USER orchestrator

# ============================================================================
# Verification
# ============================================================================
RUN claude --version && \
    git --version && \
    gh --version

CMD ["/bin/bash"]
